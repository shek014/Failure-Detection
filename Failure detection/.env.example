# Groq (free tier - get a key at console.groq.com; optional, works without it)
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=incident-resolution-agent

# Database
DATABASE_URL=sqlite:///./data/incidents.db

# Vector store
VECTOR_STORE_DIR=./data/vectors
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Monitoring
PROMETHEUS_URL=http://localhost:9090
METRICS_POLL_INTERVAL_SECONDS=30
SIMULATE_METRICS=true
ACTIVE_SCENARIO=random

# Detection thresholds
CPU_THRESHOLD=95.0
MEMORY_THRESHOLD=90.0
ERROR_RATE_THRESHOLD=5.0
LATENCY_THRESHOLD_MS=2000.0

# Human-in-the-loop
AUTO_RESOLVE_LOW_RISK=true
REQUIRE_APPROVAL_HIGH_RISK=true

# App
LOG_LEVEL=INFO
STREAMLIT_PORT=8501
